# ============================================================
# springboot-kafka-microservices — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the .env file with real credentials to version control.
#
#   cp .env.example .env
# ============================================================

# ── Java ────────────────────────────────────────────────────
JAVA_VERSION=17

# ── order-service ───────────────────────────────────────────
# Port the order-service listens on (default: 8081)
ORDER_SERVER_PORT=8081

# ── billing-service ─────────────────────────────────────────
# Port the billing-service listens on (default: 8082)
BILLING_SERVER_PORT=8082

# ── MySQL — order-service ────────────────────────────────────
# Variables used in order-service/src/main/resources/application.properties
DB_HOST=<database-host>
DB_PORT=3306
DB_NAME=order_db
DB_USERNAME=<database-user>
DB_PASSWORD=<database-password>

# ── MySQL — billing-service ──────────────────────────────────
# Note: billing-service connects to a separate schema (billing_db).
# If running on the same host, set DB_HOST to the same value.
# DB_HOST=<database-host>       (same variable, reuse)
# DB_PORT=3306                  (same variable, reuse)
BILLING_DB_NAME=billing_db
# DB_USERNAME=<database-user>   (same variable, reuse)
# DB_PASSWORD=<database-password> (same variable, reuse)

# ── Apache Kafka ─────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=<kafka-host>:9092

# Kafka consumer group (billing-service)
KAFKA_CONSUMER_GROUP_ID=billing-group

# ── Kafka Topics ─────────────────────────────────────────────
KAFKA_TOPIC_ORDER_CREATED=order-created
